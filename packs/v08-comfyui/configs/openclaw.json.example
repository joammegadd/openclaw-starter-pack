{
  "meta": {
    "lastTouchedVersion": "2026.2.26",
    "lastTouchedAt": "2026-03-03T02:52:19.388Z"
  },
  "wizard": {
    "lastRunAt": "2026-03-03T01:40:00.530Z",
    "lastRunVersion": "2026.2.26",
    "lastRunCommand": "configure",
    "lastRunMode": "local"
  },
  "auth": {
    "profiles": {
      "openai-codex:default": {
        "provider": "openai-codex",
        "mode": "oauth"
      }
    }
  },
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://ollama:11434",
        "api": "ollama",
        "models": [
          { "id": "qwen2.5:7b", "name": "Qwen 2.5 7B (Ollama)" }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai-codex/gpt-5.3-codex"
      },
      "models": {
        "openai-codex/gpt-5.3-codex": {}
      },
      "memorySearch": {
        "provider": "ollama",
        "model": "mxbai-embed-large",
        "remote": {
          "baseUrl": "http://ollama:11434"
        }
      },
      "workspace": "/home/node/.openclaw/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    },
    "list": [
      { "id": "lerry", "workspace": "~/.openclaw/workspace/agents/lerry" },
      { "id": "mia", "workspace": "~/.openclaw/workspace/agents/mia", "model": {"primary": "ollama/qwen2.5:7b"} }
    ]
  },
  "tools": {
    "web": {
      "search": {
        "provider": "brave",
        "apiKey": "${BRAVE_API_KEY}"
      }
    },
    "media": {
      "audio": {
        "enabled": true,
        "echoTranscript": true,
        "models": [
          {
            "type": "cli",
            "command": "whisper-cli",
            "args": [
              "-m", "/opt/whisper.cpp/models/ggml-base.bin",
              "-l", "pt",
              "-f", "{{MediaPath}}"
            ],
            "timeoutSeconds": 90
          }
        ]
      }
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "bindings": [
    {
      "agentId": "lerry",
      "match": {
        "channel": "slack",
        "accountId": "lerrySlack"
      }
    },
    {
      "agentId": "mia",
      "match": {
        "channel": "slack",
        "accountId": "miaSlack"
      }
    }
  ],
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "groups": {
        "*": {
          "requireMention": true
        }
      },
      "groupPolicy": "allowlist",
      "streaming": "off"
    },
    "slack": {
      "mode": "socket",
      "webhookPath": "/slack/events",
      "enabled": true,
      "userTokenReadOnly": true,
      "groupPolicy": "allowlist",
      "dmPolicy": "allowlist",
      "allowFrom": [
        "U0AJ4T10R7C"
      ],
      "nativeStreaming": true,
      "streaming": "partial",
      "accounts":{
        "lerrySlack":{
          "enabled": true,
          "userTokenReadOnly": true,
          "groupPolicy": "open",
          "dmPolicy": "allowlist",
          "nativeStreaming": true,
          "streaming": "partial",
          "botToken": "${SLACK_LERRY_BOT_TOKEN}",
          "appToken": "${SLACK_LERRY_APP_TOKEN}",
          "allowFrom": [
            "U0AJ4T10R7C"
          ]
        },
        "miaSlack":{
          "enabled": true,
          "userTokenReadOnly": true,
          "groupPolicy": "open",
          "dmPolicy": "allowlist",
          "nativeStreaming": true,
          "streaming": "partial",
          "botToken": "${SLACK_MIA_BOT_TOKEN}",
          "appToken": "${SLACK_MIA_APP_TOKEN}",
          "allowFrom": [
            "U0AJ4T10R7C"
          ]
        }
      }
    }
  },
  "skills": {
    "entries": {
      "nano-banana-pro": {
        "enabled": true,
        "apiKey": {
          "source": "env",
          "provider": "default",
          "id": "GEMINI_API_KEY"
        }
      }
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": [
        "http://127.0.0.1:18789",
        "http://localhost"
      ]
    },
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "calendar.add",
        "contacts.add",
        "reminders.add"
      ]
    }
  },
  "acp": {
    "allowedAgents": [
      "lerry"
    ]
  }
}
